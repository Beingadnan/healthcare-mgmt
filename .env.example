# Copy to .env.local and fill values from https://cloud.appwrite.io (or your self-hosted console).
# The error "Invalid URL" / input 'undefined/users' means NEXT_PUBLIC_ENDPOINT (and usually the block below) is not set.

# Appwrite API — required for server actions (users, database, storage, messaging)
NEXT_PUBLIC_ENDPOINT=https://cloud.appwrite.io/v1
PROJECT_ID=
API_KEY=

DATABASE_ID=
PATIENT_COLLECTION_ID=
DOCTOR_COLLECTION_ID=
APPOINTMENT_COLLECTION_ID=

# Storage bucket — public id for file URLs in the patient form
NEXT_PUBLIC_BUCKET_ID=

# Admin UI gate (must match what you type in the passkey modal)
NEXT_PUBLIC_ADMIN_PASSKEY=111111
